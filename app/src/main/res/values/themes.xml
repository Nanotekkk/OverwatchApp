<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.OverwatchApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/text_primary_light</item>
        <item name="android:windowBackground">@color/window_bg_light</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/window_bg_light</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Overwatch.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Overwatch.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Overwatch.Large</item>
    </style>

    <style name="ShapeAppearance.Overwatch.Small" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Overwatch.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.Overwatch.Large" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">22dp</item>
    </style>
</resources>