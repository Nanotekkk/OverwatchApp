<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:orientation="vertical">

    <include layout="@layout/toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_surface_card"
            android:elevation="3dp"
            android:padding="20dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/detailHeroImage"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:contentDescription="Hero portrait"
                android:background="@drawable/bg_portrait_frame"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_hero_placeholder" />

            <TextView
                android:id="@+id/detailHeroName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Nom"
                android:textColor="@color/text_primary_light"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detailHeroRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Rôle"
                android:textColor="@color/text_primary_light"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detailHeroStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Stats"
                android:textColor="@color/text_primary_light" />

            <TextView
                android:id="@+id/detailHeroLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Localisation"
                android:textColor="@color/text_primary_light" />

            <TextView
                android:id="@+id/detailHeroDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Description"
                android:textColor="@color/text_primary_light"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
