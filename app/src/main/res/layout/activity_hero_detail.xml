<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include layout="@layout/toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/detailHeroImage"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:contentDescription="Hero portrait"
                android:src="@drawable/ic_hero_placeholder" />

            <TextView
                android:id="@+id/detailHeroName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Nom"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detailHeroRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Rôle"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detailHeroStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Stats" />

            <TextView
                android:id="@+id/detailHeroLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Localisation" />

            <TextView
                android:id="@+id/detailHeroDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Description"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
