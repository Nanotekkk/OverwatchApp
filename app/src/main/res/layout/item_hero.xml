<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="84dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_surface_card"
    android:elevation="2dp"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/itemHeroImage"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_portrait_frame"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_hero_placeholder"
        android:contentDescription="Hero image" />

    <TextView
        android:id="@+id/itemHeroName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingStart="14dp"
        android:text="Hero name"
        android:textColor="@color/text_primary_light"
        android:textSize="17sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/itemHeroFavorite"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="2dp"
        android:src="@drawable/ic_star_outline"
        android:contentDescription="Favorite" />

</LinearLayout>
